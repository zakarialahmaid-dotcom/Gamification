  // Block submissions that look like placeholder / test data.
  const testNameRe=/^(test|tset|ttest|demo|user|admin|fake|dummy|sample|essai|exemple|example|azerty|qwerty|asdf|aaa+|bbb+|ccc+|xxx+|yyy+|zzz+|abc|123|nom|name|prénom|prenom|foo|bar|baz)$/i;
