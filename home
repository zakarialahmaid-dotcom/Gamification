// LEADERBOARD
async function fetchLeaderboard(){
  const tq=encodeURIComponent('SELECT B,C,E ORDER BY E DESC LIMIT 50'); // C=email for player matching
  const url=`https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&gid=${SHEET_GID}&tq=${tq}`;
  try{
    const res=await fetch(url);
    const text=await res.text();
    const json=JSON.parse(text.replace(/^[^(]+\(/,'').replace(/\);?\s*$/,''));
    if(!json.table?.rows)return[];
    return json.table.rows
      .filter(r=>r.c?.[2]?.v!=null)
      .map(r=>({name:String(r.c[0]?.v||'Joueur'),email:String(r.c[1]?.v||'').toLowerCase().trim(),score:Number(String(r.c[2]?.v||0).replace(/[\s,]/g,''))||0}))
      .sort((a,b)=>b.score-a.score)
      .filter((p,i,arr)=>arr.findIndex(x=>x.name===p.name)===i)
      .slice(0,50);
  }catch(e){return[];}
}


