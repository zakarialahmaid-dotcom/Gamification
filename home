<!-- ============================================================
     WEBVIEW SAFETY LAYER — Storage Polyfill + Global Error Boundary
     Must execute before any other script to protect against:
       · Blocked localStorage/sessionStorage in restricted Android WebViews
       · Silent uncaught JS exceptions that cause white-screen crashes
     ============================================================ -->
<script>
(function() {
  'use strict';

  /* ── 1. STORAGE POLYFILL ──────────────────────────────────
     Restricted Android WebViews (e.g. inside third-party apps)
     throw a SecurityError when any code touches window.localStorage
     or window.sessionStorage — even just reading the property.
     We probe each storage type with a real setItem() call inside
     try/catch, and swap in a plain in-memory object if it fails.
     The polyfill matches the Web Storage API surface exactly so
     all downstream code works without modification.
  ──────────────────────────────────────────────────────────── */
  function MemStorage() {
    var _s = {};
    return {
      get length() { return Object.keys(_s).length; },
      key: function(n) { return Object.keys(_s)[n] || null; },
      getItem: function(k) {
        return Object.prototype.hasOwnProperty.call(_s, k) ? _s[k] : null;
      },
      setItem:    function(k, v) { _s[String(k)] = String(v); },
      removeItem: function(k)    { delete _s[k]; },
      clear:      function()     { _s = {}; }
    };
  }

  ['localStorage', 'sessionStorage'].forEach(function(name) {
    try {
      /* A real write+delete test — property access alone isn't enough;
         some hosts expose the object but throw on mutation.           */
      window[name].setItem('__jg__', '1');
      window[name].removeItem('__jg__');
    } catch (e) {
      var poly = MemStorage();
      try {
        Object.defineProperty(window, name, {
          value: poly, writable: true, configurable: true
        });
      } catch (e2) {
        try { window[name] = poly; } catch (e3) { /* fully locked — ignore */ }
      }
      console.warn('[JumiaGame] ' + name + ' unavailable — using in-memory polyfill.');
    }
  });


  /* ── 2. GLOBAL ERROR BOUNDARY ────────────────────────────
     Catches any unhandled JS exception that would otherwise
     produce a completely silent white screen. Renders a
     branded fallback so users know what happened and how to
     proceed, while also logging diagnostic info to console.
  ──────────────────────────────────────────────────────────── */
  var _fallbackShown = false;

  function showFallback(msg, src, line) {
    if (_fallbackShown) return;
    _fallbackShown = true;

    /* Cancel any running rAF game loop */
    try { if (window.animId) cancelAnimationFrame(window.animId); } catch (e) {}

    var fallbackHTML = [
      '<div style="',
        'font-family:Arial,sans-serif;',
        'background:#ff9900;',
        'color:#fff;',
        'min-height:100vh;',
        'display:flex;',
        'flex-direction:column;',
        'align-items:center;',
        'justify-content:center;',
        'padding:32px 24px;',
        'text-align:center;',
        'box-sizing:border-box;',
      '">',
        '<div style="font-size:52px;margin-bottom:16px;">&#x26BD;</div>',
        '<div style="font-size:26px;font-weight:900;line-height:1.1;margin-bottom:12px;letter-spacing:-0.5px;">',
          'JUMIA<br>GARDIEN DE BUT',
        '</div>',
        '<div style="background:rgba(0,0,0,0.2);border-radius:8px;padding:16px 20px;',
          'font-size:14px;line-height:1.6;max-width:320px;margin-bottom:20px;">',
          '<strong>Ouvre ce jeu dans ton navigateur</strong><br>',
          'pour profiter de l\'exp&eacute;rience compl&egrave;te.<br><br>',
          '<span style="opacity:0.7;font-size:12px;">Chrome &middot; Firefox &middot; Safari</span>',
        '</div>',
        '<a href="https://www.jumia.ma" style="',
          'background:#ec2326;',
          'color:#fff;',
          'padding:14px 28px;',
          'border-radius:6px;',
          'font-weight:900;',
          'text-decoration:none;',
          'font-size:14px;',
          'letter-spacing:0.06em;',
          'box-shadow:0 4px 0 #a31a1d;',
        '">JUMIA.MA</a>',
        (msg
          ? '<div style="margin-top:20px;opacity:0.4;font-size:10px;word-break:break-all;max-width:320px;">'
            + 'ERR: ' + String(msg).substring(0, 140)
            + (src ? ' &nbsp;|&nbsp; ' + String(src).replace(/.*\//, '') + ':' + line : '')
            + '</div>'
          : ''),
      '</div>'
    ].join('');

    try {
      var appEl  = document.getElementById('app');
      var loadEl = document.getElementById('loading-screen');
      if (loadEl) loadEl.style.display = 'none';
      if (appEl) {
        appEl.innerHTML = fallbackHTML;
        appEl.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;overflow-y:auto;z-index:999999;';
      } else {
        document.body.innerHTML = fallbackHTML;
        document.body.style.cssText = 'margin:0;padding:0;overflow-y:auto;';
      }
    } catch (domErr) {
      /* If even DOM writes fail we are in a totally broken environment */
      try { document.write(fallbackHTML); } catch (e) { /* nothing more we can do */ }
    }
  }

  /* Synchronous uncaught exceptions */
  window.onerror = function(msg, src, line, col, errObj) {
    var detail = (errObj && errObj.stack) ? errObj.stack : msg;
    console.error('[JumiaGame] Uncaught error:', detail, '\n  at', src, line + ':' + col);
    showFallback(msg, src, line);
    return true; /* suppress default browser error dialog */
  };

  /* Async / Promise rejections */
  window.addEventListener('unhandledrejection', function(evt) {
    var reason = evt.reason
      ? (evt.reason.message || String(evt.reason))
      : 'Unhandled Promise rejection';
    console.error('[JumiaGame] Unhandled rejection:', reason);
    /* Only escalate to full fallback if we are still on the loading screen
       (i.e. the game never successfully initialised).                       */
    var loadEl  = document.getElementById('loading-screen');
    var loading = loadEl
      && loadEl.style.display !== 'none'
      && !loadEl.classList.contains('fade-out');
    if (loading) showFallback(reason, '', '');
  });

})();
</script>
<!-- END WEBVIEW SAFETY LAYER -->
