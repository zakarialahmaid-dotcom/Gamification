.lbd-back{width:clamp(36px,9vw,42px);height:clamp(36px,9vw,42px);border-radius:50%;background:rgba(255,255,255,.1);border:none;cursor:pointer;color:var(--white);font-size:clamp(16px,4vw,20px);display:flex;align-items:center;justify-content:center;flex-shrink:0;-webkit-tap-highlight-color:transparent;}
