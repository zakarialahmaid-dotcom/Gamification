.btn-replay-full.confirm{border-color:var(--red);color:var(--red);background:rgba(236,35,38,.08);font-weight:900;}
.rs-no-attempts{text-align:center;font-size:clamp(10px,2.8vw,12px);color:rgba(26,36,56,.6);font-family:var(--H2);padding:10px 0;font-weight:500;}
/* ── VOUCHER POPUP MODAL ─────────────────────────────────────────────────── */
#voucher-popup{
  position:fixed;top:0;left:0;right:0;bottom:0;
