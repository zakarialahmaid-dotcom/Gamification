.lbd-card{background:var(--white);border-radius:12px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,.1);}
.lbd-row{display:flex;align-items:center;padding:clamp(12px,3vw,15px) clamp(14px,3.5vw,18px);gap:12px;border-bottom:1px solid rgba(0,0,0,.06);}
.lbd-row:last-child{border-bottom:none;}
.lbd-row.top1{background:#fffbee;}
.lbd-row.top2{background:#fafafa;}
.lbd-row.top3{background:#fff8f2;}
.lbd-medal{width:clamp(28px,7vw,34px);height:clamp(28px,7vw,34px);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:clamp(12px,3vw,14px);font-weight:900;font-family:var(--H1);flex-shrink:0;}
.lbd-medal.gold{background:var(--orange);color:var(--navy);}
