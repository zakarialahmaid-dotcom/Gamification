function showFlash(x,y,text,good){
  const field=$('game-field');if(!field)return;
  const el=document.createElement('div');
  el.className='flash-msg';el.textContent=text;
  el.style.cssText=`left:${x}px;top:${y}px;background:${good?'#ff9900':'#ec2326'};color:${good?'#1a2438':'#fff'};`;
