.lbd-nav{flex:0 0 auto;background:var(--navy);display:flex;align-items:stretch;border-top:1px solid var(--navyL);}

/* ── PODIUM — product-first design ── */
.lb-podium{margin-bottom:clamp(10px,2.5vw,14px);}
.lb-podium-header{display:flex;align-items:center;gap:8px;margin-bottom:clamp(10px,2.5vw,13px);}
.lb-podium-header-icon{width:clamp(20px,5vw,24px);height:clamp(20px,5vw,24px);background:rgba(26,36,56,.12);border-radius:5px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.lb-podium-title{font-size:clamp(11px,3vw,13px);font-weight:900;color:var(--navy);font-family:var(--H1);text-transform:uppercase;letter-spacing:.1em;}
.lb-podium-see-all{margin-left:auto;font-size:clamp(9px,2.3vw,11px);font-weight:700;color:var(--navy);font-family:var(--H2);text-decoration:underline;cursor:pointer;opacity:.6;}

