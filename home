  const testCityRe=/^(test|tset|demo|fake|city|ville|here|there|abc|aaa+|bbb+|xxx+|yyy+|zzz+|123|azerty|qwerty|asdf|foo|bar|baz|n\/a|na|none|aucune|aucun|partout|anywhere|somewhere|nowhere)$/i;
  // Also block entries where any field is pure repeated characters (e.g. "aaaa", "1111")
  const repeatedRe=/^(.)\1{2,}$/;

  const nameIsTest  = testNameRe.test(name)  || repeatedRe.test(name)  || name.length<2;
