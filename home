.lbd-info{flex:1;min-width:0;}
.lbd-name{font-size:clamp(14px,3.8vw,17px);font-weight:700;color:var(--inkCard);font-family:var(--H2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.lbd-city{font-size:clamp(10px,2.5vw,11px);color:var(--inkCard2);font-family:var(--H2);margin-top:1px;}
.lbd-right{text-align:right;flex-shrink:0;}
.lbd-score{font-size:clamp(14px,3.8vw,17px);font-weight:900;color:var(--navy);font-family:var(--H1);}
.lbd-prize{font-size:clamp(9px,2.3vw,10px);font-weight:700;color:var(--orange);font-family:var(--H2);margin-top:2px;white-space:nowrap;}
.lbd-empty{text-align:center;padding:clamp(28px,7vw,40px) 20px;color:var(--inkCard2);font-family:var(--H2);font-size:clamp(12px,3vw,14px);}
