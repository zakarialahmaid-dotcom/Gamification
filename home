// OLD navHelp replaced

function showNavOverlay(icon,title,body,btnLabel,btnAction){
  var old=$('nav-overlay');if(old)old.remove();
  var el=document.createElement('div');
  el.id='nav-overlay';
  el.style.cssText='position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(10,15,25,.8);z-index:200;display:flex;align-items:flex-end;justify-content:center;animation:fadeIn .2s ease;';

  var sheet=document.createElement('div');
  sheet.style.cssText='background:#1a2438;border-radius:18px 18px 0 0;width:100%;max-width:480px;padding:clamp(22px,6vw,32px) clamp(20px,5vw,28px) clamp(24px,6vw,36px);box-shadow:0 -6px 32px rgba(0,0,0,.5);';

  var iconEl=document.createElement('div');
  iconEl.style.cssText='font-size:36px;text-align:center;margin-bottom:10px;';
  if(icon && (icon.startsWith('http')||icon.startsWith('data:')||icon.startsWith('/')||icon.startsWith('.'))) {
    var img=document.createElement('img');
    img.src=icon;img.style.cssText='width:40px;height:40px;object-fit:contain;display:block;margin:0 auto;';
    iconEl.appendChild(img);
  } else if(icon) {
    iconEl.textContent=icon;
  }

  var titleEl=document.createElement('div');
  titleEl.style.cssText='font-size:clamp(20px,6vw,26px);font-weight:900;color:#fff;font-family:var(--H1);text-align:center;text-transform:uppercase;margin-bottom:12px;line-height:1;';
  titleEl.textContent=title;

  var bodyEl=document.createElement('div');
  bodyEl.style.cssText='font-size:clamp(13px,3.5vw,15px);color:rgba(255,255,255,.72);font-family:var(--H2);line-height:1.55;margin-bottom:22px;text-align:center;';
  bodyEl.innerHTML=body;

  var closeBtn=document.createElement('button');
  closeBtn.textContent='FERMER';
  closeBtn.style.cssText='width:100%;background:transparent;color:rgba(255,255,255,.4);border:none;padding:10px;font-size:clamp(12px,3.2vw,14px);cursor:pointer;font-family:var(--H2);text-transform:uppercase;letter-spacing:.04em;';
  closeBtn.addEventListener('click',function(){el.remove();});

  sheet.appendChild(iconEl);
  sheet.appendChild(titleEl);
  sheet.appendChild(bodyEl);

  if(btnLabel){
    var actionBtn=document.createElement('button');
    actionBtn.textContent=btnLabel;
    actionBtn.style.cssText='width:100%;background:#ec2326;color:#fff;border:none;border-radius:10px;padding:clamp(15px,4vw,18px);font-size:clamp(15px,4.2vw,18px);font-weight:900;cursor:pointer;letter-spacing:.06em;font-family:var(--H1);text-transform:uppercase;box-shadow:0 5px 0 #a31a1d;margin-bottom:10px;display:block;';
    actionBtn.addEventListener('click',function(){el.remove();if(btnAction)btnAction();});
    sheet.appendChild(actionBtn);
  }
  sheet.appendChild(closeBtn);
  el.appendChild(sheet);
  el.addEventListener('pointerdown',function(e){if(e.target===el)el.remove();});
  document.body.appendChild(el);
}

// PRELOADER
function preloadAssets(){
  const images=[IMG_GLOVES,IMG_SOCCER,IMG_GOLDEN,IMG_REDCARD,
    'https://raw.githubusercontent.com/Madzack69/Icons/main/Maillot.webp',
    'https://raw.githubusercontent.com/Madzack69/Icons/main/Polo.webp',
    'https://raw.githubusercontent.com/Madzack69/Icons/main/Ballon.webp',
    "https://raw.githubusercontent.com/Madzack69/Icons/main/Stadium.webp"];
  const bar=$('loading-bar'),sub=$('loading-sub'),gWrap=$('loading-gloves-wrap');
  const total=images.length+1;let loaded=0,finished=false;
  function tick(){
    loaded++;
    const pct=Math.round((loaded/total)*100);
    if(bar)bar.style.width=pct+'%';
    if(loaded>=5&&gWrap&&!gWrap.querySelector('img')){const g=new Image();g.className='loading-gloves';g.src=IMG_GLOVES;g.alt='';gWrap.appendChild(g);}
    if(loaded>=total&&!finished)finish();
  }
  function finish(){
    finished=true;
    if(sub)sub.textContent='Prêt !';
    if(bar)bar.style.width='100%';
    setTimeout(()=>{
      requestAnimationFrame(()=>{
        const screen=$('loading-screen');
        if(screen)screen.classList.add('fade-out');
        setTimeout(()=>{const s2=$('loading-screen');if(s2)s2.remove();renderLobby();},420);
      });
    },400);
  }
  images.forEach(src=>{const img=new Image();img.onload=tick;img.onerror=tick;img.src=src;});
  music.addEventListener('canplaythrough',tick,{once:true});
  music.addEventListener('error',tick,{once:true});
  music.load();
  setTimeout(()=>{if(!finished)finish();},8000);
}

preloadAssets();
</script>
