  popup.appendChild(sheet);
  document.body.appendChild(popup);

  // Copy button
  const copyBtn=$('vp-copy-btn');
  if(copyBtn){
    copyBtn.addEventListener('click',function(e){
      e.stopPropagation();
      copyCode(v.code,copyBtn);
    });
  }

  // Main CTA
  const ctaBtn=$('vp-cta-btn');
  if(ctaBtn){
    ctaBtn.addEventListener('click',function(){
      // Copy code first, then open Jumia
      if(navigator.clipboard&&window.isSecureContext){
        navigator.clipboard.writeText(v.code).catch(()=>{});
      }
      window.open('https://www.jumia.ma/mlp-foot-20253/?utm_source=game&utm_medium=gamification&utm_campaign=gardien-de-but&utm_content=voucher-'+v.label.toLowerCase().replace(/\s+/g,'-'),'_blank');
      popup.remove();
      renderLobby();
    });
  }

  // Dismiss
  const dismissBtn=$('vp-dismiss-btn');
  if(dismissBtn){
    dismissBtn.addEventListener('click',function(){
      popup.remove();
    });
  }

  // Tap backdrop to dismiss
  popup.addEventListener('pointerdown',function(e){
    if(e.target===popup)popup.remove();
  });
}

