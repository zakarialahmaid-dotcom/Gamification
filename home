function endGame(finalScore){
  if(done)return;done=true;
  cancelAnimationFrame(animId);
  stopMusic();
  if(finalScore>=150)vWon++;
  totalPts+=finalScore;scoreVal=finalScore;
  attempts=Math.max(0,attempts-1);
  if(finalScore>bestScore)bestScore=finalScore;
  hasPlayedOnce=true;
  if(SHEET_URL.startsWith("https://")&&playerName){
    const params=new URLSearchParams({timestamp:new Date().toISOString(),name:playerName+(playerLastName?' '+playerLastName:''),email:playerEmail,city:playerCity,score:finalScore,combo:Math.min(maxComboVal,3),survie:Math.floor(elapsedSec),voucher:getVoucher(finalScore).code,source:'JumiaGardienDeBut'});
    fetch(SHEET_URL+'?'+params.toString(),{method:'GET',mode:'no-cors'}).catch(()=>{});
  }
  // If player hasn't given info yet, show form then result
  // If already registered, go straight to result
  if(!playerName){
    goTo(()=>renderFormPost());
  } else {
    goTo(renderResult);
  }
}

