}
.rs-low-score-title{font-size:clamp(16px,4.5vw,20px);font-weight:900;color:var(--red);font-family:var(--H1);margin-bottom:6px;}
.rs-low-score-sub{font-size:clamp(12px,3vw,14px);color:rgba(255,255,255,.6);font-family:var(--H2);line-height:1.5;}

.rs-spacer{flex:1;min-height:clamp(8px,2vw,12px);}







/* Code box — Selective Yellow tint (#fff2d6) per brand palette */
.v-code{background:#fff8e6;border:2px dashed var(--orange);border-radius:6px;padding:clamp(9px,2.2vw,13px) 20px;font-size:clamp(14px,4vw,18px);font-weight:900;color:var(--ink);letter-spacing:.18em;display:inline-block;font-family:var(--H1);}



/* Result CTA — 10% Red, consistent with all other primary CTAs */
.btn-jumia-main{display:flex;align-items:center;justify-content:center;gap:12px;width:100%;background:var(--navy);color:var(--white);border:none;border-radius:10px;padding:clamp(16px,4.5vw,20px) clamp(14px,3.5vw,20px);font-size:clamp(16px,4.5vw,20px);font-weight:900;cursor:pointer;text-decoration:none;box-shadow:0 5px 0 var(--orangeD);font-family:var(--H1);letter-spacing:.06em;text-transform:uppercase;transition:transform .1s,box-shadow .1s;}
.btn-jumia-main:active{transform:translateY(5px);box-shadow:0 0 0 var(--navyL);}
.btn-jumia-main span{line-height:1.2;}

.rs-spacer{flex:0 0 clamp(10px,2.5vw,14px);}
/* Replay bar — white footer, consistent with form card style */
.rs-replay-bar{flex:0 0 auto;padding:clamp(10px,2.5vw,14px) clamp(16px,4vw,22px) clamp(24px,6vw,30px);background:var(--orange);border-top:1px solid rgba(26,36,56,.12);}
/* Replay button — ink border, brand orange on hover */
.btn-replay-full{display:block;width:100%;background:transparent;color:var(--navy);border:2px solid var(--navy);border-radius:8px;padding:clamp(12px,3vw,15px);font-size:clamp(12px,3.2vw,14px);font-weight:700;cursor:pointer;font-family:var(--H2);text-transform:uppercase;letter-spacing:.05em;transition:border-color .2s,color .2s,background .2s;}
