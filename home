// GAME LOOP
function tick(ts){
  if(done)return;
  if(tutorialActive){lastT=null;animId=requestAnimationFrame(tick);return;}
  if(!lastT)lastT=ts;
  const dt=Math.min((ts-lastT)/16,3);lastT=ts;
  const fw=getFW(),fh=getFH(),cy=CATCH_Y(fh);
  elapsedSec+=dt/60;
  speedVal=Math.min(4.0,1.1+elapsedSec*0.03);
  spawnInt=Math.max(800,2200-elapsedSec*20);
  const spd=7+elapsedSec*0.08;
  if(pressDir==='l')gloveX=Math.max(GW/2,gloveX-spd*dt);
  if(pressDir==='r')gloveX=Math.min(fw-GW/2,gloveX+spd*dt);
  const ge=$('glove-el');
  if(ge)ge.style.transform=`translateX(${gloveX-GW/2}px)`;
  if(ts-lastSpawn>spawnInt){
    const item=spawnItem(speedVal);itemsArr.push(item);lastSpawn=ts;addItemEl(item);
    if(elapsedSec>45&&Math.random()<0.30){
      setTimeout(()=>{if(done)return;const item2=spawnItem(speedVal*0.85);itemsArr.push(item2);addItemEl(item2);},350);
    }
  }
  let livesLost=0,ptsGained=0,newCombo=comboVal,closestRedDist=9999;
  itemsArr=itemsArr.filter(item=>{
    item.y+=item.speed*dt;
    const el=$('w-'+item.id);
    if(el)el.style.top=item.y+'px';
    const cx=item.x+item.width/2;
    const inGlove=cx>=gloveX-GW/2&&cx<=gloveX+GW/2;
    if(item.type==='redcard'){
      const distY=cy-item.y;
      if(distY>0&&distY<closestRedDist)closestRedDist=distY;
      if(distY<100&&el)el.classList.add('danger-close');
      else if(el)el.classList.remove('danger-close');
    }
    if(item.y+item.height*0.5>=cy&&item.y<cy+GH){
      if(inGlove){
        if(item.type==='ball'){
          newCombo++;
          const pts=Math.round((25+Math.floor(elapsedSec)*0.3)*Math.min(newCombo,3));
          ptsGained+=pts;
          showFlash(Math.min(Math.max(cx-30,0),fw-80),cy-44,'+'+pts+' GOAL!',true);sfxCatch();
          triggerCatchRing(gloveX,cy);
          if(ge){ge.classList.add('catching');setTimeout(()=>ge&&ge.classList.remove('catching'),300);}
        } else if(item.type==='golden'){
          newCombo++;
          const pts=Math.round((75+Math.floor(elapsedSec)*0.3)*Math.min(newCombo,3));
          ptsGained+=pts;
          showFlash(Math.min(Math.max(cx-40,0),fw-100),cy-44,'BONUS +'+pts,true);sfxGolden();
          triggerCatchRing(gloveX,cy);
          if(ge){ge.classList.add('catching');setTimeout(()=>ge&&ge.classList.remove('catching'),300);}
        } else {
          // Red card — skip if within 180ms of button press (swipe protection)
          if(Date.now()-lastPressTime<180){if(el)el.remove();return false;}
          newCombo=0;livesLost++;
          showFlash(Math.min(Math.max(cx-40,0),fw-100),cy-50,'CARTON !',false);sfxRedCard();
          const sg=$('screen-game');
          if(sg){sg.classList.add('hit-flash');setTimeout(()=>sg&&sg.classList.remove('hit-flash'),400);}
          if(ge){ge.classList.remove('big-shake');void ge.offsetWidth;ge.classList.add('big-shake');setTimeout(()=>ge&&ge.classList.remove('big-shake'),500);}
        }
        if(el)el.remove();return false;
      }
    }
    if(item.y>fh+10){
      // Missed ball resets combo — catch streak must be maintained
      if(item.type==='ball'||item.type==='golden'){comboVal=0;const cb=$('combo-badge');if(cb)cb.style.display='none';}
      if(el)el.remove();return false;
    }
    return true;
  });
  const db=$('danger-bar'),dh=$('dodge-hint');
  if(db){
    if(closestRedDist<120){
      const intensity=Math.max(0,(120-closestRedDist)/120);
      db.style.height=(intensity*8)+'px';db.style.opacity=intensity;
      if(dh){dh.style.top=(cy-48-(intensity*12))+'px';dh.style.opacity=closestRedDist<60?'1':'0';}
    } else {db.style.height='0';db.style.opacity='0';if(dh)dh.style.opacity='0';}
  }
  comboVal=newCombo;
  if(newCombo>maxComboVal)maxComboVal=newCombo;
  if(ptsGained){
    scoreVal+=ptsGained;
    const sd=$('score-disp');if(sd)sd.textContent=scoreVal;
    // Tier-up celebration
    const tierMap=[{t:2000,l:'LÉGENDE',d:'20% DE RÉD.'},{t:800,l:'CHAMPION',d:'15% DE RÉD.'},{t:300,l:'MATCH READY',d:'10% DE RÉD.'}];
    for(const tier of tierMap){
      if(scoreVal>=tier.t&&lastTierReached<tier.t){lastTierReached=tier.t;showTierUp(tier.l,tier.d);break;}
    }
    // Update tier bar

    // Update score circle ring colour by tier
    const circle=$('.score-circle')||document.querySelector('.score-circle');
    const badge=$('gm-tier-badge');
    if(circle){
      let ring,label;
      if(scoreVal>=2000){ring='0 4px 20px rgba(0,0,0,.5),0 0 0 3px rgba(255,230,100,1),0 0 14px 4px rgba(255,220,50,.6)';label='20%';}
      else if(scoreVal>=800){ring='0 4px 20px rgba(0,0,0,.5),0 0 0 3px rgba(255,186,0,1),0 0 10px 2px rgba(255,186,0,.5)';label='15%';}
      else if(scoreVal>=300){ring='0 4px 20px rgba(0,0,0,.5),0 0 0 3px rgba(255,153,0,1),0 0 8px 2px rgba(255,153,0,.4)';label='10%';}
      else{ring='0 4px 20px rgba(0,0,0,.5),0 0 0 3px rgba(255,255,255,.25)';label='5%';}
      circle.style.boxShadow=ring;
      if(badge&&badge.textContent!==label){badge.textContent=label;badge.style.opacity='1';setTimeout(()=>{if(badge)badge.style.opacity='.65';},800);}
    }
  }
  const cb=$('combo-badge');
  if(cb){cb.style.display=newCombo>1?'inline-block':'none';cb.textContent='×'+Math.min(newCombo,3)+' COMBO';}
  if(livesLost){livesVal=Math.max(0,livesVal-livesLost);updateLivesDisplay();if(livesVal<=0){endGame(scoreVal);return;}}
  animId=requestAnimationFrame(tick);
}

function addItemEl(item){
