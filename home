/* Code row */
.vp-code-row{
  display:flex;align-items:center;gap:10px;
  margin-bottom:clamp(14px,3.5vw,18px);
}
.vp-code{
  flex:1;
  background:#fff8e6;
  border:2px dashed var(--orange);
  border-radius:8px;
  padding:clamp(12px,3vw,15px) 14px;
