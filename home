:root{
  /* ══════════════════════════════════════════════
     60 / 30 / 10  COLOUR SYSTEM
     60% → --orange #ff9900  Jumia Orange (dominant brand surface)
     30% → --white  #ffffff  White        (cards, panels, text)
     10% → --navy   #1a2438  Deep Navy    (accents, badges, headers)
     ══════════════════════════════════════════════ */
  --orange: #ff9900;        /* 60% — dominant Jumia brand surface */
  --orangeD:#e68800;        /* orange shadow */
  --orangeL:#ffb333;        /* orange light — hover tints */
  --white:  #ffffff;        /* 30% — cards, panels, text on orange */
  --whiteT: rgba(255,255,255,0.15); /* subtle white tint */
  --navy:   #1a2438;        /* 10% — CTAs, badges, card headers */
  --navyL:  #24304f;        /* navy light — secondary accents */
  --navyM:  #2e3d5c;        /* navy mid — borders, dividers */
  --red:    #ec2326;        /* danger only — in-game red card */
  --redD:   #a31a1d;        /* red shadow */
  /* ── Text ─────────────────────────── */
  --ink:    #1a2438;        /* primary text on orange surfaces */
  --inkSub: rgba(26,36,56,0.60); /* secondary text on orange */
  --inkCard:#1a2438;        /* primary text on white cards */
  --inkCard2:#5a6a80;       /* secondary text on white cards */
  /* ── Legacy aliases (keep code working) ── */
  --c60:  #ff9900;  --c60d: #e68800;
  --c10:  #ec2326;  --c10d: #a31a1d;
  --c30:  #ffffff;  --c30t: rgba(255,255,255,0.10);
  --yellow:#ff9900; /* yellow usages → orange */
  --green: #ff9900; /* green usages → orange */
  --ink2:  #5a6a80; --ink3: #8a9ab0;
  --tint-yellow:#fff5e0; --tint-peach:#f0dcc2; --tint-white:#f8fbff;
  --H1:'HelveticaDisplay','Gotham','Arial Black',Arial,sans-serif;
  --H2:'HelveticaText','Gotham',Arial,sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html{width:100%;height:100%;overflow:hidden;margin:0;padding:0;overscroll-behavior:none;-webkit-overflow-scrolling:touch;}
body{width:100%;height:100%;overflow:hidden;background:var(--orange);display:flex;align-items:stretch;justify-content:center;margin:0;padding:0;overscroll-behavior:none;touch-action:none;}
#app{width:100%;max-width:100%;height:100%;display:flex;flex-direction:column;background:var(--orange);overflow:hidden;font-family:var(--H1);position:relative;touch-action:none;}

/* LOADING */
/* Loading — Orange Peel bg, white headline, progress bar */
#loading-screen{position:fixed;top:0;left:0;right:0;bottom:0;background:var(--orange);z-index:99999;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20px;transition:opacity .4s ease;}
#loading-screen.fade-out{opacity:0;pointer-events:none;}
/* Headline at 95% leading per brand type rules */
.loading-logo{font-size:clamp(36px,12vw,52px);font-weight:900;color:var(--navy);font-family:var(--H1);line-height:.95;text-align:center;text-transform:uppercase;letter-spacing:-.01em;}
.loading-gloves-wrap{height:clamp(56px,15vw,72px);display:flex;align-items:center;justify-content:center;}
.loading-gloves{height:100%;width:auto;filter:drop-shadow(0 4px 12px rgba(0,0,0,.3));}
/* Sub = 50% headline size, subdued white */
.loading-sub{font-size:clamp(10px,2.8vw,13px);color:rgba(26,36,56,.7);font-family:var(--H2);font-weight:700;text-transform:uppercase;letter-spacing:.12em;}
/* Progress bar — Selective Yellow on white tint track */
.loading-bar-wrap{width:clamp(160px,45vw,220px);height:5px;background:rgba(26,36,56,.18);border-radius:3px;overflow:hidden;}
.loading-bar{height:100%;width:0%;background:var(--navy);border-radius:3px;transition:width .25s ease;}

/* ROTATE */
#rotate-screen{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:var(--orange);z-index:99998;flex-direction:column;align-items:center;justify-content:center;gap:16px;}
#rotate-screen.show{display:flex;}
.rotate-icon{font-size:56px;animation:rotatePulse 1.5s ease infinite;}
@keyframes rotatePulse{0%,100%{transform:rotate(0deg);}50%{transform:rotate(-90deg);}}
.rotate-msg{font-size:clamp(16px,5vw,20px);font-weight:900;color:var(--navy);font-family:var(--H1);text-align:center;line-height:1.2;}
.rotate-sub{font-size:clamp(11px,3vw,13px);color:rgba(255,255,255,.7);font-family:var(--H2);text-align:center;}
@media (orientation:landscape) and (max-height:500px){body{display:none;}}

/* ANIMATIONS */
@keyframes floatUp{0%{opacity:1;transform:translateY(0) scale(1.2)}100%{opacity:0;transform:translateY(-70px) scale(0.7)}}
@keyframes shake{0%,100%{margin-left:0}20%{margin-left:-8px}40%{margin-left:8px}60%{margin-left:-5px}80%{margin-left:5px}}
@keyframes fadeIn{0%{opacity:0;transform:translateY(16px)}100%{opacity:1;transform:translateY(0)}}
@keyframes screenFlash{0%,100%{background:#ff9900}40%{background:#c01010}70%{background:#d41515}}
@keyframes bigShake{0%,100%{margin-left:0}15%{margin-left:-14px}30%{margin-left:14px}45%{margin-left:-10px}60%{margin-left:10px}75%{margin-left:-6px}90%{margin-left:6px}}
@keyframes itemIn{0%{opacity:0;transform:scale(0.4)}100%{opacity:1;transform:scale(1)}}
@keyframes goldenSpin{0%{transform:rotate(0deg) scale(1)}50%{transform:rotate(180deg) scale(1.15)}100%{transform:rotate(360deg) scale(1)}}
@keyframes dangerPulse{0%,100%{opacity:.7;transform:scale(1)}50%{opacity:1;transform:scale(1.1)}}
@keyframes dotPulse{0%,100%{opacity:1;}50%{opacity:.3;}}
@keyframes arrowBounce{0%{transform:translateY(0);}100%{transform:translateY(10px);}}
@keyframes wipeIn{0%{transform:scaleY(0);border-radius:60% 60% 0 0/40px 40px 0 0;}65%{transform:scaleY(1.04);border-radius:4px 4px 0 0;}100%{transform:scaleY(1);border-radius:0;}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes tierUpIn{0%{opacity:0;transform:scale(.7);}60%{transform:scale(1.05);}100%{opacity:1;transform:scale(1);}}
@keyframes ctaBounce{
  0%,100%{transform:translateY(0);}
  50%{transform:translateY(-5px);}
}
@keyframes ctaGlow{
  0%,100%{box-shadow:0 5px 0 var(--navyL), 0 0 0 0 rgba(26,36,56,0);}
  50%{box-shadow:0 5px 0 var(--navyL), 0 0 0 10px rgba(26,36,56,0.18), 0 0 28px 4px rgba(26,36,56,0.13);}
}
@keyframes ctaArrowPulse{
  0%,100%{transform:translateX(0);}
  50%{transform:translateX(5px);}
}

/* ══════════════════════════════════════════════════════
   60/30/10 COLOUR RULE — enforced across all screens
   60% → #ff9900 Orange Peel  (all backgrounds & surfaces)
   30% → #ffffff White        (all cards, panels, readable areas)
   10% → #ec2326 Jumia Red    (all CTAs, buttons, accents)
   ══════════════════════════════════════════════════════ */

/* LOBBY */
#screen-lobby{flex:1;display:flex;flex-direction:column;background:var(--orange);padding:0;overflow:hidden;animation:fadeIn .25s ease;}

/* ── 60% Orange hero header ── */
.lb-hero{flex:0 0 auto;background:var(--orange);padding:clamp(14px,3.5vw,20px) clamp(16px,4vw,22px) clamp(10px,2.5vw,14px);display:flex;align-items:center;justify-content:space-between;gap:10px;position:relative;}
.lb-hero-left{flex:1;min-width:0;}
.lb-eyebrow{font-size:clamp(9px,2.4vw,11px);font-weight:700;letter-spacing:.13em;color:rgba(26,36,56,.75);font-family:var(--H2);text-transform:uppercase;margin-bottom:4px;}
.lb-title{font-size:clamp(38px,11vw,54px);font-weight:900;color:var(--navy);line-height:.88;font-family:var(--H1);letter-spacing:-.01em;text-transform:uppercase;}
.lb-hero-ball{position:absolute;right:clamp(84px,23vw,112px);bottom:0;width:clamp(52px,14vw,68px);height:auto;pointer-events:none;filter:drop-shadow(0 4px 10px rgba(0,0,0,.3));}
/* ── 30% White badge with red accent ── */
.lb-attempts-badge{flex-shrink:0;background:var(--white);border-radius:10px;padding:clamp(8px,2vw,12px) clamp(12px,3vw,16px);text-align:center;box-shadow:0 4px 16px rgba(0,0,0,.3);min-width:clamp(72px,18vw,88px);}
.lb-attempts-icon{font-size:clamp(14px,3.5vw,18px);margin-bottom:2px;display:block;}
.lb-attempts-num{font-size:clamp(26px,7.5vw,34px);font-weight:900;font-family:var(--H1);line-height:1;color:var(--inkCard);}
.lb-attempts-num.urgent{color:var(--red);}
.lb-attempts-lbl{font-size:clamp(7px,1.8vw,9px);font-weight:700;color:var(--navy);font-family:var(--H2);text-transform:uppercase;letter-spacing:.06em;margin-top:2px;}

/* ── Scrollable body ── */
.lb-scroll{flex:1;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch;overscroll-behavior:contain;padding:clamp(10px,2.5vw,14px) clamp(14px,3.5vw,18px) clamp(14px,3.5vw,18px);}
.lb-scroll::-webkit-scrollbar{display:none;}

/* ── 30% White leaderboard card ── */
.lb-board{border-radius:12px;overflow:hidden;background:var(--white);box-shadow:0 4px 20px rgba(0,0,0,.12);margin-bottom:clamp(10px,2.5vw,14px);}
/* 10% Red header strip */
.lb-board-header{display:flex;align-items:center;justify-content:space-between;padding:clamp(10px,2.5vw,13px) clamp(14px,3.5vw,18px);background:var(--navyL);}
.lb-board-header-left{display:flex;align-items:center;gap:8px;}
.lb-board-trophy{width:clamp(20px,5vw,24px);height:clamp(20px,5vw,24px);object-fit:contain;filter:brightness(0) saturate(100%) invert(60%) sepia(90%) saturate(500%) hue-rotate(1deg) brightness(105%);}
.lb-board-title{font-size:clamp(11px,3vw,14px);font-weight:900;color:var(--c30);font-family:var(--H1);letter-spacing:.08em;text-transform:uppercase;}
.lb-board-live{font-size:clamp(9px,2.3vw,11px);font-weight:700;color:rgba(255,255,255,.8);font-family:var(--H2);display:flex;align-items:center;gap:5px;}
.lb-board-live::before{content:'';width:7px;height:7px;border-radius:50%;background:var(--c30);display:inline-block;animation:dotPulse 1.4s ease infinite;}
.lb-board-rows{max-height:clamp(190px,52vw,240px);overflow-y:auto;-webkit-overflow-scrolling:touch;overscroll-behavior:contain;}
.lb-board-rows::-webkit-scrollbar{width:3px;}
.lb-board-rows::-webkit-scrollbar-thumb{background:rgba(0,0,0,.1);border-radius:2px;}
.lb-board-row{display:flex;align-items:center;padding:clamp(9px,2.3vw,12px) clamp(14px,3.5vw,18px);gap:10px;border-bottom:1px solid rgba(0,0,0,.06);}
.lb-board-row:last-child{border-bottom:none;}
.lb-rank{font-size:clamp(12px,3.2vw,15px);font-weight:900;width:24px;text-align:center;flex-shrink:0;color:var(--inkCard2);font-family:var(--H2);}
.lb-board-row.top1 .lb-rank{color:var(--navy);}
.lb-board-row.top3 .lb-rank{color:var(--navy);}
.lb-name{flex:1;font-size:clamp(13px,3.5vw,16px);font-weight:700;color:var(--inkCard);font-family:var(--H2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.lb-score{font-size:clamp(12px,3.2vw,14px);font-weight:900;color:var(--navy);font-family:var(--H1);flex-shrink:0;}
.lb-prize{flex-shrink:0;font-size:clamp(9px,2.3vw,11px);font-weight:700;font-family:var(--H2);padding:3px 9px;border-radius:5px;white-space:nowrap;margin-left:4px;background:var(--orange);color:var(--navy);}
.lb-scroll-hint{text-align:center;padding:clamp(6px,1.5vw,8px);font-size:clamp(9px,2.3vw,11px);color:var(--inkCard2);font-family:var(--H2);border-top:1px solid rgba(0,0,0,.06);}
.lb-board-msg{text-align:center;padding:clamp(14px,3.5vw,18px);font-size:clamp(11px,2.8vw,13px);color:var(--inkCard2);font-family:var(--H2);}

/* ── How-to-play — 30% white cards ── */
.lb-how{margin-bottom:clamp(10px,2.5vw,14px);}
.lb-how-header{display:flex;align-items:center;gap:8px;margin-bottom:clamp(8px,2vw,11px);}
.lb-how-header-icon{width:clamp(20px,5vw,24px);height:clamp(20px,5vw,24px);background:rgba(26,36,56,.15);border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:clamp(11px,2.8vw,13px);flex-shrink:0;}
.lb-how-title{font-size:clamp(11px,3vw,13px);font-weight:900;color:var(--navy);font-family:var(--H1);text-transform:uppercase;letter-spacing:.1em;}
.lb-how-rows{display:flex;flex-direction:column;gap:clamp(8px,2vw,10px);}

/* White how-to card */
.lb-how-row{display:flex;align-items:center;gap:clamp(10px,2.5vw,14px);background:var(--white);border-radius:10px;padding:clamp(12px,3vw,16px);box-shadow:0 3px 10px rgba(0,0,0,.1);}
.lb-how-icon{flex-shrink:0;width:clamp(44px,11vw,54px);height:clamp(44px,11vw,54px);border-radius:50%;background:rgba(255,153,0,.12);border:2px solid rgba(255,153,0,.35);display:flex;align-items:center;justify-content:center;}
.lb-how-icon img{width:clamp(28px,7vw,34px);height:clamp(28px,7vw,34px);object-fit:contain;display:block;}
.lb-how-text{flex:1;min-width:0;}
.lb-how-action{font-size:clamp(13px,3.5vw,16px);font-weight:900;color:var(--inkCard);font-family:var(--H1);text-transform:uppercase;line-height:1.1;margin-bottom:3px;}
.lb-how-sub{font-size:clamp(10px,2.6vw,12px);color:var(--inkCard2);font-family:var(--H2);line-height:1.3;}
/* 10% Red tags */
.lb-how-tag{flex-shrink:0;font-size:clamp(10px,2.8vw,12px);font-weight:900;font-family:var(--H1);padding:clamp(7px,1.8vw,9px) clamp(11px,2.8vw,14px);border-radius:6px;text-transform:uppercase;letter-spacing:.04em;white-space:nowrap;background:var(--navy);color:var(--white);box-shadow:0 3px 0 var(--navyL);min-width:60px;text-align:center;}
.lb-how-tag.green{background:var(--navy);color:var(--white);box-shadow:0 3px 0 var(--navyL);}
