  const cityIsTest  = testCityRe.test(city)  || repeatedRe.test(city)  || city.length<2;

  const fields=[
    ['inp-name',  'err-name',  !name  || nameIsTest,  nameIsTest  ? 'Prénom invalide' : 'Prénom requis'],
    ['inp-email', 'err-email', !emailRe.test(email)||emailIsTest, emailIsTest ? 'E-mail invalide'  : 'E-mail valide requis'],
    ['inp-city',  'err-city',  !city  || cityIsTest,  cityIsTest  ? 'Ville invalide'  : 'Ville requise'],
  ];
  fields.forEach(([inp,err,fail,msg])=>{
    $(inp)?.classList.toggle('error',fail);
    const em=$(err);
    if(em){em.textContent=msg;em.classList.toggle('visible',fail);}
    if(fail)valid=false;
  });
