.lbd-sub{font-size:clamp(10px,2.5vw,12px);color:rgba(255,255,255,.55);font-family:var(--H2);margin-top:2px;}
.lbd-live{display:flex;align-items:center;gap:5px;font-size:clamp(9px,2.3vw,11px);font-weight:700;color:rgba(255,255,255,.7);font-family:var(--H2);}
