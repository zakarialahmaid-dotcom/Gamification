(function(){
  let wasPlayingOnHide=false;

  function onHide(){
    wasPlayingOnHide=musicOn&&musicStarted&&!music.paused;
    if(wasPlayingOnHide){musicFade(0,200);setTimeout(()=>music.pause(),220);}
  }
  function onShow(){
    if(wasPlayingOnHide&&musicOn){music.play().catch(()=>{});musicFade(0.18,400);}
    wasPlayingOnHide=false;
  }

  // Standard Page Visibility API — fires when tab is switched, app backgrounded, screen locked
  document.addEventListener('visibilitychange',()=>{
    document.hidden ? onHide() : onShow();
  });

  // pagehide covers page unload / back-forward cache on mobile browsers
  window.addEventListener('pagehide', onHide);
  window.addEventListener('pageshow', e=>{
    // pageshow fires on bfcache restore (persisted=true) — resume if needed
    if(e.persisted) onShow();
  });

  // window blur/focus catches the WebView losing focus inside a third-party app
  window.addEventListener('blur', onHide);
